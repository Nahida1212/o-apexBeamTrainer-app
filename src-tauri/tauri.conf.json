{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "o-apexbeamtrainer-app",
  "version": "0.1.0",
  "identifier": "com.tauri-app.o-apexbeamtrainer-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "o-apexbeamtrainer-app",
        "width": 800,
        "height": 600
      },
      {
        "label": "direction-overlay",
        "title": "Direction Overlay",
        "url": "#/direction-overlay",
        "width": 280,
        "height": 180,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "center": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
